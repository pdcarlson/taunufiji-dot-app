# Copy to `.env.local` and replace placeholders with real values.
# Never commit `.env.local` or real secrets.
#
# Schema: `lib/infrastructure/config/server-env-schema.ts`
#
# --- Full stack (OAuth, Appwrite, S3, Discord) ---
# For lint / unit tests / build without credentials, use:
#   SKIP_ENV_VALIDATION=true npm run build
# (see CONTRIBUTING.md and AGENTS.md)

# App (public)
NEXT_PUBLIC_APPWRITE_ENDPOINT=https://cloud.appwrite.io/v1
NEXT_PUBLIC_APPWRITE_PROJECT_ID=your-appwrite-project-id
NEXT_PUBLIC_APP_URL=[REDACTED]

# Appwrite (server)
APPWRITE_API_KEY=your-appwrite-api-key

# AWS S3 (Library module)
AWS_ACCESS_KEY_ID=your-aws-access-key-id
AWS_BUCKET_NAME=your-s3-bucket-name
AWS_REGION=us-east-1
AWS_SECRET_ACCESS_KEY=your-aws-secret-access-key

# Discord (bot + guild + roles + housing channel)
DISCORD_APP_ID=000000000000000000
DISCORD_BOT_TOKEN=your-discord-bot-token
DISCORD_GUILD_ID=000000000000000000
DISCORD_HOUSING_CHANNEL_ID=000000000000000000
DISCORD_PUBLIC_KEY=your-discord-application-public-key
DISCORD_ROLE_ID_BROTHER=000000000000000000
DISCORD_ROLE_ID_CABINET=000000000000000000
DISCORD_ROLE_ID_HOUSING_CHAIR=000000000000000000

# Cron-protected routes (`/api/cron/*`)
# Optional in schema; omit only if you do not hit cron locally.
CRON_SECRET=your-random-cron-secret

# Optional: set to `true` to skip validation (e.g. CI scripts, local build without services).
# SKIP_ENV_VALIDATION=true
